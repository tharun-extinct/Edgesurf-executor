{
  "manifest_version": 3,
  "name": "EdgeSurf Executor",
  "version": "1.0.0",
  "description": "Keyboard shortcuts for Edge Surf game (edge://surf). Press R to restart.",
  "permissions": ["debugger", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "EdgeSurf Executor"
  }
}
